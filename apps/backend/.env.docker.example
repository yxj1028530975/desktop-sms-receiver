APP_NAME=SMS Desktop Notifier
ENVIRONMENT=production
DATABASE_URL=sqlite:////app/data/sms.db
LOG_DIR=/app/logs
APT_MAIN_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian
APT_SECURITY_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/debian-security
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
UV_DEFAULT_INDEX=https://pypi.tuna.tsinghua.edu.cn/simple
UV_HTTP_TIMEOUT=180
INBOUND_API_KEY=change-this-inbound-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_SESSION_SECRET=change-this-session-secret
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_HISTORY_ITEMS=200
